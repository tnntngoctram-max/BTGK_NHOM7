@using BTGK_NHOM7.Entities
@model List<ToeicExam>

@{
    ViewBag.Title = "Danh sách Đề thi TOEIC";
}

<div class="content d-flex flex-column flex-column-fluid" id="kt_content">
    <div class="container-fluid">
        <div class="card shadow-sm mt-5 border-0" style="border-radius: 12px;">
            <div class="card-header bg-white py-4 d-flex justify-content-between align-items-center">
                <h3 class="card-title font-weight-bolder text-primary mb-0">
                    <i class="fas fa-book-open mr-2"></i> Danh sách Đề thi TOEIC
                </h3>
                <a asp-action="Index" class="btn btn-info font-weight-bold shadow-sm">
                    <i class="fas fa-upload mr-1"></i> Tải lên đề mới
                </a>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover table-striped mb-0">
                    <thead class="thead-light font-weight-bold">
                        <tr>
                            <th class="text-center" style="width: 5%">STT</th>
                            <th>Tên đề thi</th>
                            <th class="text-center" style="width: 15%">Thời gian</th>
                            <th class="text-center" style="width: 20%">Ngày tạo</th>
                            <th class="text-center" style="width: 20%">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            for (int i = 0; i < Model.Count; i++)
                            {
                                var exam = Model[i];
                                <tr style="transition: background-color 0.2s;">
                                    <td class="text-center align-middle">@(i + 1)</td>
                                    <td class="align-middle font-weight-bold text-dark" style="font-size: 1.1rem;">@exam.Title</td>
                                    <td class="text-center align-middle"><span class="badge badge-secondary px-3 py-2">@exam.TimeMinutes phút</span></td>
                                    <td class="text-center align-middle">@exam.CreationTime.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-center align-middle">
                                        <a asp-action="Exam" asp-route-id="@exam.Id" class="btn btn-sm btn-success font-weight-bold mr-2 shadow-sm">
                                            <i class="fas fa-edit"></i> Làm bài
                                        </a>
                                        <a asp-action="Preview" asp-route-id="@exam.Id" class="btn btn-sm btn-light text-primary font-weight-bold border shadow-sm">
                                            <i class="fas fa-eye"></i> Xem trước
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">
                                    Chưa có đề thi nào trong hệ thống. Vui lòng tải lên đề thi mới!
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>