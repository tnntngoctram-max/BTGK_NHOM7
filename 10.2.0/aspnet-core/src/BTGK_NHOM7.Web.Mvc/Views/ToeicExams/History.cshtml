@using BTGK_NHOM7.ToeicExams.Dto
@model List<UserExamHistoryDto>
@{
    ViewBag.Title = "Lịch sử làm bài";
}

<div class="content d-flex flex-column flex-column-fluid mt-5">
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <h2 class="font-weight-bolder text-primary m-0">
                <i class="fas fa-history text-warning mr-2"></i> Lịch sử làm bài của bạn
            </h2>
            
            <a asp-action="List" class="btn btn-light-primary font-weight-bold rounded-pill px-4 py-2 shadow-sm">
                <i class="fas fa-arrow-left mr-2"></i> Trở về danh sách
            </a>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle">
                        <thead class="thead-light">
                            <tr>
                                <th>Ngày làm bài</th>
                                <th>Tên đề thi</th>
                                <th class="text-center">Số câu đúng</th>
                                <th class="text-center">Số câu sai</th>
                                <th class="text-center">Bỏ qua</th>
                                <th class="text-center text-primary">Điểm đạt được</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Count > 0)
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.CompletionDate.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="font-weight-bold">@item.ExamName</td>
                                        <td class="text-center text-success font-weight-bold">@item.CorrectCount</td>
                                        <td class="text-center text-danger font-weight-bold">@item.WrongCount</td>
                                        <td class="text-center text-warning font-weight-bold">@item.SkipCount</td>
                                        <td class="text-center font-weight-bolder text-primary" style="font-size: 1.1rem;">@item.Score</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">Bạn chưa làm bài thi nào.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>