@using BTGK_NHOM7.Entities
@model ToeicExam

@{
    ViewBag.Title = "Chỉnh sửa Đề thi";
}

<div class="content d-flex flex-column flex-column-fluid mt-5">
    <div class="container-fluid">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-4">
                <h3 class="card-title font-weight-bolder text-primary mb-0">Chỉnh sửa thông tin đề thi</h3>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="form-group mb-4">
                        <label class="font-weight-bold">Tên đề thi <span class="text-danger">*</span></label>
                        <input type="text" name="Title" class="form-control" value="@Model.Title" required />
                    </div>
                    <div class="form-group mb-4">
                        <label class="font-weight-bold">Thời gian (phút) <span class="text-danger">*</span></label>
                        <input type="number" name="TimeMinutes" class="form-control" value="@Model.TimeMinutes" required />
                    </div>
                    <button type="submit" class="btn btn-success font-weight-bold mr-2"><i class="fas fa-save"></i> Lưu thay đổi</button>
                    <a asp-action="Preview" asp-route-id="@Model.Id" class="btn btn-light-primary font-weight-bold">Hủy</a>
                </form>
            </div>
        </div>
    </div>
</div>