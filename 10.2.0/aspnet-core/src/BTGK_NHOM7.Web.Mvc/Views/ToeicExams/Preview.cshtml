@model BTGK_NHOM7.Entities.ToeicExam

@{
    ViewData["Title"] = "Xem trước Đề Thi";
}

<div class="container-fluid">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mb-4 shadow-sm">
            @TempData["Success"]
        </div>
    }

    <div class="card shadow-sm mb-4">

        <!-- HEADER -->
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4 class="m-0 font-weight-bold text-primary">
                @Model.Title (Parse: @Model.Questions.Count/100 câu)
            </h4>
            <a asp-action="Publish" asp-route-id="@Model.Id" class="btn btn-success font-weight-bold">
                <i class="fas fa-upload"></i> Xuất bản Đề Thi
            </a>
        </div>

        <div class="card-body">

            <!-- NAV TAB -->
            <ul class="nav nav-tabs mb-3">
                <li class="nav-item">
                    <a class="nav-link active" data-bs-toggle="tab" href="#part5">Part 5</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#part6">Part 6</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#part7">Part 7</a>
                </li>
            </ul>

            <!-- TAB CONTENT -->
            <div class="tab-content">

                <!-- ================= PART 5 ================= -->
                <div class="tab-pane fade show active" id="part5">
                    @{
                        var part5 = Model.Parts.FirstOrDefault(p => p.PartNumber == 5);
                    }

                    @foreach (var q in part5?.Questions ?? new List<ToeicQuestion>())
                    {
                        <div class="border p-3 mb-3 rounded bg-light" id="question_@q.Id">
                            <div class="d-flex justify-content-between">
                                <strong>Câu @q.QuestionNumber</strong>
                                <a asp-action="EditQuestion" asp-route-id="@q.Id" asp-route-examId="@Model.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-edit"></i> Chỉnh sửa
                                </a>
                            </div>

                            <p>@q.QuestionText</p>

                            @foreach (var opt in new[] {
                                new { Key = "A", Value = q.OptionA },
                                new { Key = "B", Value = q.OptionB },
                                new { Key = "C", Value = q.OptionC },
                                new { Key = "D", Value = q.OptionD }
                            })
                            {
                                <div class="mb-1">
                                    <span class="badge @(q.CorrectAnswer == opt.Key ? "bg-success" : "bg-secondary") me-1">
                                        [@opt.Key] @opt.Value
                                </span>
                                </div>
                            }
                        </div>
                    }
                </div>


                <!-- ================= PART 6 ================= -->
                <div class="tab-pane fade" id="part6">
                    @{
                        var part6 = Model.Parts.FirstOrDefault(p => p.PartNumber == 6);
                    }

                    @foreach (var passage in part6?.Passages ?? new List<ToeicPassage>())
                    {
                        <div class="border p-3 mb-4 rounded bg-white shadow-sm">
                            <h6 class="text-primary">Đoạn văn</h6>
                            <p>@passage.Content</p>

                            @foreach (var q in passage.Questions ?? new List<ToeicQuestion>())
                            {
                                <div class="mt-3 border-top pt-2" id="question_@q.Id">
                                    <div class="d-flex justify-content-between">
                                        <strong>Câu @q.QuestionNumber</strong>
                                        <a asp-action="EditQuestion" asp-route-id="@q.Id" asp-route-examId="@Model.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-edit"></i> Chỉnh sửa
                                        </a>
                                    </div>
                                    <p>@q.QuestionText</p>

                                    @foreach (var opt in new[] {
                                        new { Key = "A", Value = q.OptionA },
                                        new { Key = "B", Value = q.OptionB },
                                        new { Key = "C", Value = q.OptionC },
                                        new { Key = "D", Value = q.OptionD }
                                    })
                                    {
                                        <div class="mb-1">
                                            <span class="badge @(q.CorrectAnswer == opt.Key ? "bg-success" : "bg-secondary") me-1">
                                                [@opt.Key] @opt.Value
                                            </span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>


                <!-- ================= PART 7 ================= -->
                <div class="tab-pane fade" id="part7">
                    @{
                        var part7 = Model.Parts.FirstOrDefault(p => p.PartNumber == 7);
                    }

                    @foreach (var passage in part7?.Passages ?? new List<ToeicPassage>())
                    {
                        <div class="border p-3 mb-4 rounded bg-white shadow-sm">
                            <h6 class="text-success">Bài đọc</h6>
                            <p>@passage.Content</p>

                            <hr />

                            @foreach (var q in passage.Questions ?? new List<ToeicQuestion>())
                            {
                                <div class="mb-3" id="question_@q.Id">
                                    <div class="d-flex justify-content-between">
                                        <strong>Câu @q.QuestionNumber</strong>
                                        <a asp-action="EditQuestion" asp-route-id="@q.Id" asp-route-examId="@Model.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-edit"></i> Chỉnh sửa
                                        </a>
                                    </div>
                                    <p>@q.QuestionText</p>

                                    @foreach (var opt in new[] {
                                        new { Key = "A", Value = q.OptionA },
                                        new { Key = "B", Value = q.OptionB },
                                        new { Key = "C", Value = q.OptionC },
                                        new { Key = "D", Value = q.OptionD }
                                    })
                                    {
                                        <div>
                                            <span class="badge @(q.CorrectAnswer == opt.Key ? "bg-success" : "bg-light text-dark")">
                                                [@opt.Key] @opt.Value
                                            </span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var examId = '@Model.Id';
            var storageKey = 'activeTab_ExamPreview_' + examId;
            
            // 1. Kiểm tra xem URL có chứa hash của câu hỏi không (ví dụ: #question_123)
            var hash = window.location.hash;
            var targetQuestion = null;
            var targetTab = null;

            if (hash && hash.startsWith('#question_')) {
                targetQuestion = $(hash);
                if (targetQuestion.length > 0) {
                    // Tìm tab chứa câu hỏi này
                    var pane = targetQuestion.closest('.tab-pane');
                    if (pane.length > 0) {
                        targetTab = '#' + pane.attr('id');
                    }
                }
            }

            // 2. Ưu tiên mở tab chứa câu hỏi từ URL hash, nếu không có thì lấy từ localStorage
            var activeTab = targetTab || localStorage.getItem(storageKey);
            
            if (activeTab) {
                $('.nav-link').removeClass('active');
                $('.tab-pane').removeClass('show active');
                
                $('a[href="' + activeTab + '"]').addClass('active');
                $(activeTab).addClass('show active');
            }

            // 3. Scroll tới câu hỏi nếu có
            if (targetQuestion && targetQuestion.length > 0) {
                setTimeout(function() {
                    $('html, body').animate({
                        scrollTop: targetQuestion.offset().top - 100 // Trừ hao khoảng cách header nếu có
                    }, 500);
                }, 200);
            }

            // 4. Lưu tab hiện tại vào bộ nhớ trình duyệt khi click chuyển tab
            $('a[data-bs-toggle="tab"]').on('shown.bs.tab click', function (e) {
                var target = $(e.currentTarget).attr("href");
                if (target && target.startsWith('#part')) {
                    localStorage.setItem(storageKey, target);
                }
            });
        });
    </script>
}