@using BTGK_NHOM7.Entities
@model ToeicExam
@{
    ViewBag.Title = "Làm bài thi: " + Model.Title;
    int qIndex = 0;
}

<style>
    .exam-header {
        position: sticky;
        top: 0;
        z-index: 1020;
        background-color: #ffffff;
        border-bottom: 2px solid #eaeaea;
    }
    .passage-box {
        background-color: #fdfdfd;
        border-left: 5px solid #17a2b8;
        line-height: 1.8;
    }
    .question-card {
        border-radius: 10px;
        transition: all 0.2s;
    }
    .question-card:hover {
        background-color: #f8f9fa;
        box-shadow: 0 4px 8px rgba(0,0,0,0.05);
    }
</style>

<div class="content d-flex flex-column flex-column-fluid" id="kt_content">
    <div class="container-fluid">
        <div class="card shadow mt-4 border-0">
            <div class="card-header exam-header d-flex justify-content-between align-items-center py-4 shadow-sm">
                <h3 class="card-title font-weight-bold text-primary mb-0">@Model.Title</h3>
                <div class="timer bg-danger text-white font-weight-bold rounded px-4 py-2 shadow" style="font-size: 1.5rem; letter-spacing: 2px;" title="Thời gian còn lại">
                    <i class="far fa-clock mr-2"></i> <span id="countdown">@Model.TimeMinutes:00</span>
                </div>
            </div>
            
            <div class="card-body">
                <form id="examForm" asp-action="SubmitExam" method="post">
                    <input type="hidden" name="examId" value="@Model.Id" />
                    @foreach (var part in Model.Parts)
                    {
                        <div class="mb-5 pb-4 border-bottom">
                            <h4 class="text-info font-weight-bolder mb-4 text-uppercase"><i class="fas fa-bookmark mr-2"></i>@part.Title</h4>
                            
                            @if (part.Passages != null && part.Passages.Any())
                            {
                                foreach (var passage in part.Passages)
                                {
                                    <div class="passage-box p-4 mb-4 rounded shadow-sm border border-light">
                                        <div style="white-space: pre-wrap; font-size: 1.15rem;" class="text-dark text-justify">@passage.Content</div>
                                    </div>
                                    <div class="pl-md-4">
                                        @foreach (var q in passage.Questions)
                                        {
                                            <div class="mb-4 question-card p-3 border border-light">
                                                <p class="font-weight-bold mb-3" style="font-size: 1.1rem;">Câu @q.QuestionNumber: <span style="white-space: pre-wrap;" class="font-weight-normal text-dark">@q.QuestionText</span></p>
                                                <input type="hidden" name="answers[@qIndex].QuestionId" value="@q.Id" />
                                                <div class="ml-2">
                                                    @if (!string.IsNullOrEmpty(q.OptionA)) { <div class="custom-control custom-radio mb-2"><input class="custom-control-input" type="radio" name="answers[@qIndex].SelectedAnswer" value="A" id="q_@(q.Id)_A"><label class="custom-control-label cursor-pointer" for="q_@(q.Id)_A"><span class="font-weight-bold">A.</span> @q.OptionA</label></div> }
                                                    @if (!string.IsNullOrEmpty(q.OptionB)) { <div class="custom-control custom-radio mb-2"><input class="custom-control-input" type="radio" name="answers[@qIndex].SelectedAnswer" value="B" id="q_@(q.Id)_B"><label class="custom-control-label cursor-pointer" for="q_@(q.Id)_B"><span class="font-weight-bold">B.</span> @q.OptionB</label></div> }
                                                    @if (!string.IsNullOrEmpty(q.OptionC)) { <div class="custom-control custom-radio mb-2"><input class="custom-control-input" type="radio" name="answers[@qIndex].SelectedAnswer" value="C" id="q_@(q.Id)_C"><label class="custom-control-label cursor-pointer" for="q_@(q.Id)_C"><span class="font-weight-bold">C.</span> @q.OptionC</label></div> }
                                                    @if (!string.IsNullOrEmpty(q.OptionD)) { <div class="custom-control custom-radio mb-2"><input class="custom-control-input" type="radio" name="answers[@qIndex].SelectedAnswer" value="D" id="q_@(q.Id)_D"><label class="custom-control-label cursor-pointer" for="q_@(q.Id)_D"><span class="font-weight-bold">D.</span> @q.OptionD</label></div> }
                                                </div>
                                            </div>
                                            qIndex++;
                                        }
                                    </div>
                                }
                            }
                            
                            @if (part.Questions != null && part.Questions.Any(q => q.PassageId == null))
                            {
                                <div class="pl-md-3 mt-3">
                                    @foreach (var q in part.Questions.Where(q => q.PassageId == null))
                                    {
                                        <div class="mb-4 question-card p-3 border border-light">
                                            <p class="font-weight-bold mb-3" style="font-size: 1.1rem;">Câu @q.QuestionNumber: <span style="white-space: pre-wrap;" class="font-weight-normal text-dark">@q.QuestionText</span></p>
                                            <input type="hidden" name="answers[@qIndex].QuestionId" value="@q.Id" />
                                            <div class="ml-2">
                                                @if (!string.IsNullOrEmpty(q.OptionA)) { <div class="custom-control custom-radio mb-2"><input class="custom-control-input" type="radio" name="answers[@qIndex].SelectedAnswer" value="A" id="q_@(q.Id)_A"><label class="custom-control-label cursor-pointer" for="q_@(q.Id)_A"><span class="font-weight-bold">A.</span> @q.OptionA</label></div> }
                                                @if (!string.IsNullOrEmpty(q.OptionB)) { <div class="custom-control custom-radio mb-2"><input class="custom-control-input" type="radio" name="answers[@qIndex].SelectedAnswer" value="B" id="q_@(q.Id)_B"><label class="custom-control-label cursor-pointer" for="q_@(q.Id)_B"><span class="font-weight-bold">B.</span> @q.OptionB</label></div> }
                                                @if (!string.IsNullOrEmpty(q.OptionC)) { <div class="custom-control custom-radio mb-2"><input class="custom-control-input" type="radio" name="answers[@qIndex].SelectedAnswer" value="C" id="q_@(q.Id)_C"><label class="custom-control-label cursor-pointer" for="q_@(q.Id)_C"><span class="font-weight-bold">C.</span> @q.OptionC</label></div> }
                                                @if (!string.IsNullOrEmpty(q.OptionD)) { <div class="custom-control custom-radio mb-2"><input class="custom-control-input" type="radio" name="answers[@qIndex].SelectedAnswer" value="D" id="q_@(q.Id)_D"><label class="custom-control-label cursor-pointer" for="q_@(q.Id)_D"><span class="font-weight-bold">D.</span> @q.OptionD</label></div> }
                                            </div>
                                        </div>
                                        qIndex++;
                                    }
                                </div>
                            }
                        </div>
                    }
                    
                    <div class="text-center mt-5 mb-3 pt-4">
                        <button type="button" class="btn btn-lg btn-success px-5 py-3 font-weight-bold shadow-lg" style="border-radius: 50px; font-size: 1.2rem;" onclick="confirmSubmit()">
                            <i class="fas fa-paper-plane mr-2"></i> Hoàn thành & Nộp bài
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let timeInSeconds = @(Model.TimeMinutes * 60);
        const countdownEl = document.getElementById('countdown');
        const form = document.getElementById('examForm');

        const timer = setInterval(() => {
            timeInSeconds--;
            let m = Math.floor(timeInSeconds / 60).toString().padStart(2, '0');
            let s = (timeInSeconds % 60).toString().padStart(2, '0');
            countdownEl.innerText = `${m}:${s}`;

            if (timeInSeconds <= 0) {
                clearInterval(timer);
                alert("Đã hết thời gian làm bài! Hệ thống sẽ tự động nộp bài.");
                form.submit();
            }
        }, 1000);

        function confirmSubmit() {
            if (confirm('Bạn có chắc chắn muốn nộp bài không?')) {
                clearInterval(timer);
                form.submit();
            }
        }
    </script>
}