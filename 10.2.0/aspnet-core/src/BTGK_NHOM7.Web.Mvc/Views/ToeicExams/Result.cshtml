@model BTGK_NHOM7.ToeicExams.Dto.ResultDto
@{
    ViewBag.Title = "Kết quả bài thi";
    
    int timeTaken = ViewBag.TimeTakenSeconds != null ? (int)ViewBag.TimeTakenSeconds : 0;
    string timeStr = $"{timeTaken / 60} phút {timeTaken % 60} giây";
}

<style>
    .score-circle {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        transition: transform 0.3s;
    }
    .score-circle:hover {
        transform: scale(1.05);
    }
    .part-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border-radius: 12px;
    }
    .part-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.1) !important;
    }
    .stat-box { background: #fff; border-radius: 12px; padding: 1.5rem; box-shadow: 0 4px 15px rgba(0,0,0,0.05); border: 1px solid #e9ecef; }
</style>

<div class="content d-flex flex-column flex-column-fluid mt-4" id="kt_content">
    <div class="container">
        <div class="card shadow-sm border-0 mb-5" style="border-radius: 15px;">
            <div class="card-body py-5 px-md-5">
                
                <div class="text-center mb-5 pb-4 border-bottom">
                    <h2 class="font-weight-bolder text-primary mb-4"><i class="fas fa-trophy text-warning mr-2"></i> BÁO CÁO KẾT QUẢ TOEIC READING</h2>
                    
                    <div class="score-circle mx-auto my-4 d-flex align-items-center justify-content-center border border-white rounded-circle text-white" style="width:200px; height:200px; border-width: 8px !important;">
                        <div class="text-center">
                            <h1 class="m-0 display-3 font-weight-bold line-height-sm">@Model.Score</h1>
                            <span style="font-size: 1.2rem; opacity: 0.8">/ 495 điểm</span>
                        </div>
                    </div>
                </div>

                <!-- Bảng Thống kê -->
                <div class="row mb-5">
                    <div class="col-md-3 col-6 mb-3">
                        <div class="stat-box text-center h-100">
                            <i class="fas fa-stopwatch text-info mb-2" style="font-size: 2rem;"></i>
                            <h5 class="font-weight-bolder text-dark mt-2">@timeStr</h5>
                            <span class="text-muted font-weight-bold">Thời gian làm bài</span>
                        </div>
                    </div>
                    <div class="col-md-3 col-6 mb-3">
                        <div class="stat-box text-center h-100">
                            <i class="fas fa-check-circle text-success mb-2" style="font-size: 2rem;"></i>
                            <h5 class="font-weight-bolder text-success mt-2">@Model.CorrectCount câu</h5>
                            <span class="text-muted font-weight-bold">Số câu đúng</span>
                        </div>
                    </div>
                    <div class="col-md-3 col-6 mb-3">
                        <div class="stat-box text-center h-100">
                            <i class="fas fa-times-circle text-danger mb-2" style="font-size: 2rem;"></i>
                            <h5 class="font-weight-bolder text-danger mt-2">@Model.WrongCount câu</h5>
                            <span class="text-muted font-weight-bold">Số câu sai</span>
                        </div>
                    </div>
                    <div class="col-md-3 col-6 mb-3">
                        <div class="stat-box text-center h-100">
                            <i class="fas fa-minus-circle text-warning mb-2" style="font-size: 2rem;"></i>
                            <h5 class="font-weight-bolder text-warning mt-2">@Model.SkipCount câu</h5>
                            <span class="text-muted font-weight-bold">Bỏ qua</span>
                        </div>
                    </div>
                </div>

                @if (Model.PartAnalysis != null && Model.PartAnalysis.Any())
                {
                    <h4 class="text-dark font-weight-bolder mb-4"><i class="fas fa-chart-bar text-primary mr-2"></i> Phân tích chi tiết từng phần</h4>
                    <div class="row">
                        @foreach(var part in Model.PartAnalysis) {
                            var progressColor = part.Percentage >= 80 ? "bg-success" : part.Percentage >= 50 ? "bg-warning" : "bg-danger";
                            <div class="col-md-4 mb-4">
                                <div class="card text-center shadow-sm h-100 border-0 part-card bg-light">
                                    <div class="card-header border-0 bg-transparent font-weight-bold pt-4 pb-0 text-secondary" style="font-size: 1.2rem;">
                                        Part @part.PartNumber
                                    </div>
                                    <div class="card-body d-flex flex-column justify-content-center">
                                        <h2 class="text-dark font-weight-bolder mb-3">@part.CorrectCount <small class="text-muted" style="font-size: 1rem;">/ @part.TotalCount</small></h2>
                                        <div class="progress rounded-pill shadow-sm mb-2" style="height: 12px; background-color: #e4e6ef;">
                                            <div class="progress-bar @progressColor" role="progressbar" style="width: @part.Percentage%" aria-valuenow="@part.Percentage" aria-valuemin="0" aria-valuemax="100"></div>
                                        </div>
                                        <span class="font-weight-bold @(part.Percentage >= 80 ? "text-success" : part.Percentage >= 50 ? "text-warning" : "text-danger")">
                                            Đạt tỷ lệ @part.Percentage%
                                        </span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }

                <div class="text-center mt-5 pt-3 border-top">
                    <a asp-action="List" class="btn btn-light-primary btn-lg px-5 py-3 font-weight-bolder mr-3 rounded-pill">
                        <i class="fas fa-list mr-2"></i> Về danh sách đề thi
                    </a>
                    <a asp-action="Index" class="btn btn-primary btn-lg px-5 py-3 font-weight-bolder rounded-pill shadow">
                        <i class="fas fa-home mr-2"></i> Về trang chủ
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>