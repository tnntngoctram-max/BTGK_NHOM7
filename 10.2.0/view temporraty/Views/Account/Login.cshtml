@{
    Layout = "~/Views/Shared/_Layout.cshtml"; // Sử dụng layout chung để kéo CSS
}

<div class="login-box" style="margin: 7% auto;">
    <div class="login-logo">
        <a href="/"><b>TOEIC</b> Reading Online</a>
    </div>
    <div class="card card-outline card-primary shadow">
        <div class="card-body login-card-body">
            <p class="login-box-msg">Đăng nhập để bắt đầu phiên làm việc</p>
            <form asp-action="Login" method="post">
                <div class="input-group mb-3">
                    <input type="text" name="UsernameOrEmailAddress" class="form-control" placeholder="Tên đăng nhập">
                    <div class="input-group-append">
                        <div class="input-group-text"><span class="fas fa-user"></span></div>
                    </div>
                </div>
                <div class="input-group mb-3">
                    <input type="password" name="Password" class="form-control" placeholder="Mật khẩu">
                    <div class="input-group-append">
                        <div class="input-group-text"><span class="fas fa-lock"></span></div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-8">
                        <div class="icheck-primary">
                            <input type="checkbox" id="remember">
                            <label for="remember">Ghi nhớ tôi</label>
                        </div>
                    </div>
                    <div class="col-4">
                        <button type="submit" class="btn btn-primary btn-block">Đăng nhập</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>