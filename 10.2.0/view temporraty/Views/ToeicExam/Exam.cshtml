<div class="row">
    <div class="col-lg-9 col-md-8 overflow-auto" style="height: 85vh;">
        <h3 class="mb-4">@Model.Title</h3>
        <div id="exam-content">
            @foreach (var part in Model.Parts) {
                <h4>Part @part.PartNumber: @part.PartTitle</h4>
                @foreach (var q in part.Questions) {
                    <div class="question mb-5" id="q-@q.QuestionNumber">
                        <p><strong>Câu @q.QuestionNumber:</strong> @q.QuestionText</p>
                        <div class="options ml-3">
                            <div class="custom-control custom-radio">
                                <input type="radio" name="ans-@q.Id" class="answer-radio" data-qid="@q.QuestionNumber" value="A"> (A) @q.OptionA
                            </div>
                            </div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="col-lg-3 col-md-4 border-left shadow-sm bg-white p-3">
        <div class="sticky-top">
            <h5 class="text-center">THỜI GIAN CÒN LẠI</h5>
            <h2 class="text-danger text-center" id="countdown">75:00</h2>
            <hr>
            <h6>Phiếu trả lời</h6>
            <div class="answer-sheet d-flex flex-wrap overflow-auto" style="max-height: 300px;">
                @for (int i = 101; i <= 200; i++) {
                    <a href="#q-@i" id="sheet-q-@i" class="btn btn-sm btn-outline-secondary m-1 rounded-circle" style="width: 35px;">@i</a>
                }
            </div>
            <button class="btn btn-danger btn-block mt-4" onclick="confirmSubmit()">NỘP BÀI THI</button>
        </div>
    </div>
</div>

<script>
    // Xử lý đổi màu phiếu trả lời khi chọn đáp án
    document.querySelectorAll('.answer-radio').forEach(radio => {
        radio.addEventListener('change', (e) => {
            const qNum = e.target.dataset.qid;
            document.getElementById(`sheet-q-${qNum}`).classList.replace('btn-outline-secondary', 'btn-primary text-white');
        });
    });

    // Đồng hồ đếm ngược 75 phút
    let time = 75 * 60;
    setInterval(() => {
        if(time <= 0) submitExam();
        let m = Math.floor(time / 60);
        let s = time % 60;
        document.getElementById('countdown').innerText = `${m}:${s < 10 ? '0' : ''}${s}`;
        time--;
    }, 1000);
</script>   